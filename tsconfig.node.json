{
  "compilerOptions": {
    "composite": true,
    "target": "ES2025",
    "lib": ["ES2025"],
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "vite.config.ts",
    "playwright.config.ts",
    "eslint.config.mjs",
    "tests"
  ]
}
